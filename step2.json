{
  "step": 2,
  "step_name": "mock_ui",
  "source_prompt": "bash.md",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>localAIv8 v8 | NOcron Control</title>\n  <style>\n    :root {\n      --bg: #0b1020;\n      --panel: #11172a;\n      --line: #2a3558;\n      --text: #e8eeff;\n      --muted: #93a2cc;\n      --ok: #3fd18a;\n      --warn: #f2b84b;\n      --danger: #ff6a6a;\n      --accent: #5ea0ff;\n    }\n    * { box-sizing: border-box; }\n    body { margin: 0; font-family: Segoe UI, Arial, sans-serif; background: radial-gradient(circle at 20% 0%, #16244a 0%, var(--bg) 45%); color: var(--text); }\n    .shell { min-height: 100vh; padding: 20px; display: grid; gap: 14px; grid-template-rows: auto auto 1fr; }\n    .bar { display: flex; justify-content: space-between; align-items: center; background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 12px 14px; }\n    .grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 14px; }\n    .card { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 14px; }\n    .muted { color: var(--muted); font-size: 12px; }\n    h1,h2,h3 { margin: 0 0 10px 0; }\n    textarea,input,select { width: 100%; background: #0c1326; color: var(--text); border: 1px solid var(--line); border-radius: 10px; padding: 10px; }\n    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }\n    .btns { display: flex; gap: 10px; flex-wrap: wrap; }\n    button { border: 1px solid var(--line); background: #172448; color: var(--text); border-radius: 10px; padding: 10px 12px; cursor: pointer; }\n    button.primary { background: #1e3a74; border-color: #3155a7; }\n    button.warn { background: #4e3a12; border-color: #7d5b1d; }\n    .pipeline { display: grid; grid-template-columns: repeat(8, minmax(120px,1fr)); gap: 8px; }\n    .step { border: 1px solid var(--line); border-radius: 10px; padding: 8px; font-size: 12px; background: #0d1429; }\n    .step.active { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent) inset; }\n    .status { display: inline-flex; gap: 8px; align-items: center; }\n    .dot { width: 8px; height: 8px; border-radius: 99px; display: inline-block; }\n    .ok { background: var(--ok); } .warnc { background: var(--warn); } .bad { background: var(--danger); }\n    .tasks { max-height: 330px; overflow: auto; border: 1px solid var(--line); border-radius: 10px; }\n    table { width: 100%; border-collapse: collapse; font-size: 12px; }\n    th,td { padding: 8px; border-bottom: 1px solid #202b4d; text-align: left; }\n  </style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"bar\">\n      <div>\n        <h1>localAIv8 v8 Control Surface</h1>\n        <div class=\"muted\">WSL2 + Ollama gemma4:26b | NOcron deterministic loop</div>\n      </div>\n      <div class=\"status\">\n        <span class=\"dot ok\"></span><span class=\"muted\">Model Ready</span>\n        <span class=\"dot warnc\"></span><span class=\"muted\">Step 2 Active</span>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <h2>Pipeline</h2>\n      <div class=\"pipeline\">\n        <div class=\"step\">0 Context+Tool</div>\n        <div class=\"step\">1 Compress</div>\n        <div class=\"step active\">2 Mock UI</div>\n        <div class=\"step\">3 HTML Parse</div>\n        <div class=\"step\">4 DAG</div>\n        <div class=\"step\">5 Scaffold+Tests</div>\n        <div class=\"step\">6 Write</div>\n        <div class=\"step\">7 Export</div>\n      </div>\n    </div>\n\n    <div class=\"grid\">\n      <div class=\"card\">\n        <h2>Build Intent Source</h2>\n        <div class=\"muted\">Source: bash.md (no compression in this run)</div>\n        <textarea rows=\"10\" readonly>Loaded from bash.md as authoritative prompt input for Step 2.</textarea>\n\n        <h3 style=\"margin-top:12px\">Controls</h3>\n        <div class=\"row\">\n          <div>\n            <label class=\"muted\">Compression Slider (disabled for this run)</label>\n            <input type=\"range\" min=\"0\" max=\"50\" value=\"0\" disabled />\n          </div>\n          <div>\n            <label class=\"muted\">Export Path</label>\n            <input placeholder=\"/mnt/d/exports/project\" value=\"\" />\n          </div>\n        </div>\n        <div class=\"btns\" style=\"margin-top:10px\">\n          <button class=\"primary\">Run Step 2</button>\n          <button>Run Step 3 Parse</button>\n          <button class=\"warn\">Manual Accelerate</button>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <h2>NOcron Execution</h2>\n        <div class=\"muted\">Initial trigger -> run one -> validate -> schedule next one -> stop</div>\n        <div class=\"tasks\" style=\"margin-top:10px\">\n          <table>\n            <thead><tr><th>Task</th><th>Status</th><th>Depends On</th></tr></thead>\n            <tbody>\n              <tr><td>T001 Normalize</td><td>complete</td><td>-</td></tr>\n              <tr><td>T002 NOcron Rules</td><td>complete</td><td>T001</td></tr>\n              <tr><td>T003 UI Layer</td><td>complete</td><td>T001</td></tr>\n              <tr><td>T004 Slider Contract</td><td>complete</td><td>T001</td></tr>\n              <tr><td>T005 Export Path</td><td>complete</td><td>T001</td></tr>\n              <tr><td>T006 Gap Policy</td><td>complete</td><td>T001</td></tr>\n              <tr><td>T007 Preserve Architecture</td><td>complete</td><td>T001..T006</td></tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  </div>\n</body>\n</html>",
  "components": [
    {"name": "HeaderStatusBar", "props": ["modelState", "activeStep"]},
    {"name": "PipelineStepper", "props": ["steps", "activeStep"]},
    {"name": "IntentPanel", "props": ["sourceFile", "compressionEnabled", "exportPath"]},
    {"name": "NocronTaskTable", "props": ["tasks", "statuses", "dependencies"]}
  ],
  "rationale_short": "Manual deterministic Step 2 mock UI generated directly from bash.md architecture while skipping Steps 0 and 1."
}