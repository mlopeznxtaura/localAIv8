Key Modified File: pipeline/ollama_client.py

```python
#!/usr/bin/env python3
import json, re, sys, time, hashlib, urllib.request, os
from pathlib import Path
from datetime import datetime
from typing import Any, Optional

# Configuration
OLLAMA_HOST = "http://172.30.80.1:11434"
TEACHER_MODEL = "gemma4:26b"
STUDENT_BASE = "google/gemma-2-9b-it"
STUDENT_LORA_PATH = Path(__file__).parent.parent / "student_model"
TRAINING_DATA_DIR = Path(__file__).parent.parent / "training_data"
TOOL_CACHE_DIR = Path(__file__).parent.parent / "tool_cache"

for d in [TRAINING_DATA_DIR, TRAINING_DATA_DIR/"raw", STUDENT_LORA_PATH, TOOL_CACHE_DIR]:
d.mkdir(exist_ok=True)

def strip_fences(text: str) -> str:
return re.sub(r'^```\w*\n', '', text, flags=re.MULTILINE).strip()

def safe_json(raw: str, fallback: Any = None) -> Any:
try:
return json.loads(strip_fences(raw))
except:
return fallback

def ask(step_num: int, step_name: str, user_content: str, budget_tokens: int = 500, require_tools: bool = False) -> str:
system_prompt = (
"You are localAIv8, a stateless build execution unit. Output JSON only. "
"Compress next_input by ≥40%. Stay under {budget_tokens} tokens. "
"If missing data, emit tool_calls array. Never hallucinate."
)
if require_tools:
system_prompt += " You MUST use web_search or fetch_url if your knowledge may be outdated (cutoff before 2025-04-01)."
payload = {
"model": TEACHER_MODEL,
"messages": [
{"role": "system", "content": system_prompt},
{"role": "user", "content": user_content}
],
"stream": False,
"options": {"temperature": 0.15, "num_predict": budget_tokens}
}
req = urllib.request.Request(f"{OLLAMA_HOST}/api/chat", data=json.dumps(payload).encode(), headers={"Content-Type": "application/json"}, method="POST")
with urllib.request.urlopen(req, timeout=60) as resp:
return json.loads(resp.read().decode())["message"]["content"]

def cache_key(data: dict) -> str:
return hashlib.md5(json.dumps(data, sort_keys=True).encode()).hexdigest()

def get_cached(key: str) -> Optional[Any]:
f = TOOL_CACHE_DIR / f"{key}.json"
return json.loads(f.read_text()) if f.exists() else None

def set_cached(key: str, result: Any):
(TOOL_CACHE_DIR / f"{key}.json").write_text(json.dumps(result))

def dump_training_data(step, step_name, substep, system_prompt, user_prompt, teacher_output, parsed_output, session_id, latency_ms, tokens_est, fallback_used):
example = {
"timestamp": datetime.utcnow().isoformat(), "session_id": session_id,
"step": step, "step_name": step_name, "substep": substep,
"system_prompt": system_prompt, "user_prompt": user_prompt,
"teacher_output_raw": teacher_output, "parsed_output": parsed_output,
"fallback_used": fallback_used, "latency_ms": latency_ms, "tokens_estimated": tokens_est
}
with open(TRAINING_DATA_DIR / "stream.jsonl", "a") as f:
f.write(json.dumps(example) + "\n")
raw_dir = TRAINING_DATA_DIR / "raw" / f"{session_id}_{step}_{substep}"
raw_dir.mkdir(parents=True, exist_ok=True)
(raw_dir / "example.json").write_text(json.dumps(example, indent=2))
(raw_dir / "teacher_output.txt").write_text(teacher_output)

def ask_with_training(step, step_name, substep, user_content, budget, session_id, require_tools=False):
start = time.time()
system_prompt = "You are localAIv8, a stateless build execution unit. Output JSON only."
raw_response = ask(step, step_name, user_content, budget, require_tools)
latency_ms = int((time.time() - start) * 1000)
parsed = safe_json(raw_response, fallback={"error": "invalid_json", "raw": raw_response})
fallback_used = isinstance(parsed, dict) and "error" in parsed
dump_training_data(step, step_name, substep, system_prompt, user_content, raw_response, parsed, session_id, latency_ms, budget, fallback_used)
return parsed
```

